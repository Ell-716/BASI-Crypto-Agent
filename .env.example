# Flask Configuration
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
FLASK_ENV=development
FLASK_DEBUG=True

# Database (auto-resolved, no change needed for local dev)
# The app automatically creates the SQLite database in backend/instance/
# DEV_DATABASE_URL=sqlite:///crypto_agent_dev.db
# TEST_DATABASE_URL=sqlite:///crypto_agent_test.db
# DATABASE_URL=sqlite:///crypto_agent.db

# Resend Email API (for email verification and password reset)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Groq LLM API
GROQ_API_KEY=your_groq_api_key_here
