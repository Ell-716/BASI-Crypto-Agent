# Flask Configuration
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
FLASK_ENV=development
FLASK_DEBUG=True

# Database (auto-resolved, no change needed for local dev)
# The app automatically creates the SQLite database in backend/instance/
# DEV_DATABASE_URL=sqlite:///crypto_agent_dev.db
# TEST_DATABASE_URL=sqlite:///crypto_agent_test.db
# DATABASE_URL=sqlite:///crypto_agent.db

# Gmail SMTP (requires Gmail App Password - regular password won't work)
# Generate at: myaccount.google.com/apppasswords (needs 2FA enabled)
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16char_app_password
MAIL_DEFAULT_SENDER=your_gmail@gmail.com

# Groq LLM API
GROQ_API_KEY=your_groq_api_key_here
